{
  "compilerOptions": {
    "module": "Node16",
    "target": "es2017",
    "lib": ["es2017"],
    "moduleResolution": "node16",
    "outDir": "lib",
    "rootDir": "src",
    "composite": true,
    "declaration": true,
    "sourceMap": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "noImplicitAny": false,
    "preserveConstEnums": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": false,
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "lib",
    "test"
  ]
}
